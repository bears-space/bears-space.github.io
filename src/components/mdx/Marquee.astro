---
// Marquee - Seamless infinite horizontal scroll component
// Uses requestAnimationFrame for smooth scrolling with touch-drag support
// Works with any content including Img components

interface Props {
  /** Scroll speed in pixels per second (default: 50) */
  speed?: number;
  /** Gap between items, any valid CSS length (default: "2rem") */
  gap?: string;
  /** Pause animation on hover (default: true) */
  pauseOnHover?: boolean;
  /** Height preset - sm: 12rem, md: 16rem, lg: 20rem, xl: 24rem (default: "md") */
  height?: "sm" | "md" | "lg" | "xl";
  /** Scroll direction (default: "left") */
  direction?: "left" | "right";
}

const {
  speed = 50,
  gap = "2rem",
  pauseOnHover = true,
  height = "md",
  direction = "left",
} = Astro.props;

const heightMap = { sm: "12rem", md: "16rem", lg: "20rem", xl: "24rem" };
const heightValue = heightMap[height];
const isReverse = direction === "right";

// Render slot to HTML so we can post-process image sizes.
// Empty marquees (no children) fall back to an empty string so the build
// doesn't crash when an editor inserts a Marquee via the CMS without items yet.
let slotHtml = (await Astro.slots.render("default")) ?? "";

// Auto-compute `sizes` for <img> tags based on marquee height and aspect ratio.
// The marquee CSS sets images to fill the content height (minus 8px top + 8px bottom
// padding), so the display width = (height - 16px) * (intrinsic width / intrinsic height).
slotHtml = slotHtml.replace(
  /<img\b([^>]*)>/gi,
  (match, attrs: string) => {
    const wMatch = attrs.match(/\bwidth="(\d+)"/);
    const hMatch = attrs.match(/\bheight="(\d+)"/);
    if (!wMatch || !hMatch) return match;

    const aspectRatio = (Number(wMatch[1]) / Number(hMatch[1])).toFixed(4);
    const computedSizes = `calc((${heightValue} - 16px) * ${aspectRatio})`;

    // Replace existing sizes or append new one
    if (/\bsizes="[^"]*"/.test(attrs)) {
      attrs = attrs.replace(/\bsizes="[^"]*"/, `sizes="${computedSizes}"`);
    } else {
      attrs += ` sizes="${computedSizes}"`;
    }

    return `<img${attrs}>`;
  }
);
---

<div
  class="not-prose marquee-better-container overflow-hidden"
  style={`--marquee-gap: ${gap}; --marquee-height: ${heightValue}; touch-action: pan-y pinch-zoom;`}
  x-data={`{
    ready: false,

    async init() {
      const content = this.$refs.content;
      const track = this.$refs.track;
      const container = this.$el;

      // No need to await image pixel data: Astro's <Image> sets width/height
      // attributes, so the browser reserves correct layout boxes via intrinsic
      // aspect-ratio and scrollWidth is accurate before images finish decoding.

      // Snapshot the original children so we can append clones from a stable list
      const originalChildren = Array.from(content.children).map(child => child.cloneNode(true));

      // Plain object for all animation state — bypasses Alpine's proxy entirely.
      // totalWidth is measured below after cloning, with sub-pixel precision.
      const s = {
        position: 0,
        totalWidth: 0,
        lastTime: performance.now(),
        isPaused: false,
        isDragging: false,
        touchStartX: 0,
        touchStartPosition: 0,
        rafId: null,
        resumeTimer: null,
        reducedMotion: window.matchMedia('(prefers-reduced-motion: reduce)').matches
      };

      const speed = ${speed};
      const isReverse = ${isReverse};
      const pauseOnHover = ${pauseOnHover};

      // Clone items until content overflows the container
      let safetyCounter = 0;
      while (content.scrollWidth <= container.clientWidth && safetyCounter < 100) {
        originalChildren.forEach(child => {
          content.appendChild(child.cloneNode(true));
        });
        safetyCounter++;
      }

      // Add one more complete set for seamless animation buffer
      originalChildren.forEach(child => {
        content.appendChild(child.cloneNode(true));
      });

      // Measure the repeat distance from the DOM with sub-pixel precision.
      // The first clone of the first original sits exactly one full set + gap to
      // the right of the original, so the difference of their fractional left
      // edges is the exact wrap distance. Using scrollWidth + parsed gap rounds
      // to integer pixels and causes a visible jump at every wrap.
      const firstOriginal = content.children[0];
      const firstClone = content.children[originalChildren.length];
      s.totalWidth = firstClone.getBoundingClientRect().left
                   - firstOriginal.getBoundingClientRect().left;

      // Single closure — reused by rAF, no allocation per frame
      const animate = (timestamp) => {
        const deltaTime = Math.min((timestamp - s.lastTime) / 1000, 0.1);
        s.lastTime = timestamp;

        if (!s.isDragging && !s.isPaused && !s.reducedMotion) {
          if (isReverse) {
            s.position -= speed * deltaTime;
            if (s.position < 0) s.position += s.totalWidth;
          } else {
            s.position += speed * deltaTime;
            if (s.position >= s.totalWidth) s.position -= s.totalWidth;
          }
        }

        track.style.transform = 'translateX(' + (-s.position) + 'px)';
        s.rafId = requestAnimationFrame(animate);
      };

      // Event handlers as closures over plain state
      this.handleTouchStart = (e) => {
        if (e.touches.length !== 1) return;
        clearTimeout(s.resumeTimer);
        s.isDragging = true;
        s.isPaused = false;
        s.touchStartX = e.touches[0].clientX;
        s.touchStartPosition = s.position;
      };

      this.handleTouchMove = (e) => {
        if (!s.isDragging) return;
        if (e.touches.length !== 1) { s.isDragging = false; return; }
        let newPosition = s.touchStartPosition - (e.touches[0].clientX - s.touchStartX);
        newPosition = newPosition % s.totalWidth;
        if (newPosition < 0) newPosition += s.totalWidth;
        s.position = newPosition;
        track.style.transform = 'translateX(' + (-s.position) + 'px)';
      };

      this.handleTouchEnd = () => {
        if (!s.isDragging) return;
        s.isDragging = false;
        s.isPaused = true;
        s.lastTime = performance.now();
        clearTimeout(s.resumeTimer);
        s.resumeTimer = setTimeout(() => {
          s.isPaused = false;
          s.lastTime = performance.now();
        }, 1000);
      };

      this.handleMouseEnter = () => {
        if (pauseOnHover) s.isPaused = true;
      };

      this.handleMouseLeave = () => {
        if (pauseOnHover) {
          s.isPaused = false;
          s.lastTime = performance.now();
        }
      };

      this.ready = true;
      s.lastTime = performance.now();
      s.rafId = requestAnimationFrame(animate);
      this._cleanup = () => { cancelAnimationFrame(s.rafId); clearTimeout(s.resumeTimer); };
    },

    destroy() {
      if (this._cleanup) this._cleanup();
    }
  }`}
  x-bind:class="{ 'marquee-ready': ready }"
  @touchstart="handleTouchStart($event)"
  @touchmove="handleTouchMove($event)"
  @touchend="handleTouchEnd()"
  @touchcancel="handleTouchEnd()"
  @mouseenter="handleMouseEnter()"
  @mouseleave="handleMouseLeave()"
>
  <div
    class="marquee-better-track"
    x-ref="track"
  >
    <div
      x-ref="content"
      class="marquee-better-content"
      style={`gap: ${gap}; height: ${heightValue};`}
    >
      <Fragment set:html={slotHtml} />
    </div>
  </div>
</div>

<style>
  .marquee-better-container {
    width: 100%;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      rgba(0, 0, 0, 0.30) 2%,
      rgba(0, 0, 0, 0.60) 5%,
      rgba(0, 0, 0, 0.82) 8%,
      rgba(0, 0, 0, 0.93) 11%,
      rgba(0, 0, 0, 0.98) 14%,
      rgba(0, 0, 0, 0.997) 17%,
      black 20%,
      black 80%,
      rgba(0, 0, 0, 0.997) 83%,
      rgba(0, 0, 0, 0.98) 86%,
      rgba(0, 0, 0, 0.93) 89%,
      rgba(0, 0, 0, 0.82) 92%,
      rgba(0, 0, 0, 0.60) 95%,
      rgba(0, 0, 0, 0.30) 98%,
      transparent 100%
    );
            mask-image: linear-gradient(
      to right,
      transparent 0%,
      rgba(0, 0, 0, 0.30) 2%,
      rgba(0, 0, 0, 0.60) 5%,
      rgba(0, 0, 0, 0.82) 8%,
      rgba(0, 0, 0, 0.93) 11%,
      rgba(0, 0, 0, 0.98) 14%,
      rgba(0, 0, 0, 0.997) 17%,
      black 20%,
      black 80%,
      rgba(0, 0, 0, 0.997) 83%,
      rgba(0, 0, 0, 0.98) 86%,
      rgba(0, 0, 0, 0.93) 89%,
      rgba(0, 0, 0, 0.82) 92%,
      rgba(0, 0, 0, 0.60) 95%,
      rgba(0, 0, 0, 0.30) 98%,
      transparent 100%
    );
  }

  /* Only show grab cursor on touch devices where dragging is supported */
  @media (pointer: coarse) {
    .marquee-better-container {
      cursor: grab;
    }

    .marquee-better-container:active {
      cursor: grabbing;
    }
  }

  .marquee-better-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  .marquee-better-content {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    padding: 8px 0;
  }

  /* Style for direct children of the content */
  .marquee-better-content > :global(*) {
    height: 100%;
    width: auto;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  /* Ensure images within marquee items fill height properly */
  .marquee-better-content :global(img) {
    height: 100%;
    width: auto;
    object-fit: cover;
  }

  /* Handle Img wrapper divs */
  .marquee-better-content > :global(.img-better) {
    height: 100%;
    width: auto !important;
    aspect-ratio: unset !important;
  }

  .marquee-better-content > :global(.img-better img) {
    height: 100%;
    width: auto;
    object-fit: cover;
  }
</style>
