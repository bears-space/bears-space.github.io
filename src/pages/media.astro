---
// Media Page - Displays all media organized by category in accordion format
// Page header (title/subtitle/seoDescription/hero image) lives in media/media-title.mdx;
// the accordion category list lives in media/media-categories.mdx.

import { getEntry } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import NotFoundPage from "./404.astro";
import MediaAccordion from "../components/reusable/MediaAccordion.astro";
import PageHeroImage from "../components/reusable/PageHeroImage.astro";
import { loadAllImagesFromDirectory, loadCollectionImages, loadImage, resolveImagePath } from "@utils/imageLoader";
import type { ImageMetadata } from "astro";
import { mediaHeroImages } from "@utils/imageGlobs";
import { getMediaItemsByCategory, getMediaPeople, getPageContent } from "@utils/contentQueries";
import { getLocale, mediaUiStrings } from "@utils/i18n";
import type { ImageWithAlt } from "@types";

const locale = getLocale(Astro.url);
const visibility = (await getEntry('media-section-visibility', 'settings'))!.data;

// When the page is hidden, we render the 404 component inline below.
// We can't use Astro.rewrite() here: the de/ locale wrapper has already
// started streaming HTML before this frontmatter runs, so a rewrite would
// throw ResponseSentError on the Cloudflare adapter.
let pageContent: Awaited<ReturnType<typeof getPageContent>> = undefined;
let heroImage: ImageMetadata | null = null;
let heroAlt = "";
const displayCategories: { id: string; label: string; images: ImageWithAlt[] }[] = [];

if (visibility.showMediaPage) {
  pageContent = await getPageContent('media/media-title', locale);
  const categoriesContent = await getPageContent('media/media-categories', locale);

  // Image is locale-agnostic; editors can only upload on the EN singleton.
  const imageEntry = await getPageContent('media/media-title', 'en');
  const imageFileName = imageEntry?.data.image || pageContent?.data.image;
  heroAlt = imageEntry?.data.imageAlt || pageContent?.data.imageAlt
    || "BEARS event showcasing student astronautics activities";

  heroImage = imageFileName
    ? await loadImage({
        glob: mediaHeroImages,
        imagePath: resolveImagePath('/src/assets/hero/media', imageFileName),
        context: { itemTitle: 'Media hero image' },
      })
    : null;

  if (!heroImage) {
    const loadedHeroImages = await loadAllImagesFromDirectory(mediaHeroImages);
    heroImage = loadedHeroImages[0] ?? null;
  }

  // Read categories from content file (order and visibility controlled by content creators)
  const contentCategories = categoriesContent?.data.mediaCategories ?? [];

  // Each category sources from a different place. People → People collection
  // filtered by showInFaces + coverImage (separate query because we need each
  // person's name + role for the alt). Everything else → getMediaItemsByCategory
  // dispatch. 'all' is a runtime aggregate of everything else.
  const loadedCategories = (await Promise.all(
    contentCategories
      .filter((cat: { id: string }) => cat.id !== 'all')
      .map(async (cat: { id: string; label: string }): Promise<{ id: string; label: string; images: ImageWithAlt[] } | null> => {
        if (cat.id === 'people') {
          const mediaPeople = await getMediaPeople(locale);
          const peopleWithImages = await loadCollectionImages(mediaPeople, 'person');
          // loadCollectionImages's type signature strips the locale-projected
          // `role` from getMediaPeople, so re-derive it here from roleEn/roleDe.
          const images: ImageWithAlt[] = peopleWithImages.map((p) => {
            const role = locale === 'de' ? p.data.roleDe : p.data.roleEn;
            return {
              image: p.loadedImage,
              alt: `${p.data.name} — ${role}`,
              description: p.data.coverImageDescription,
            };
          });
          return { id: cat.id, label: cat.label, images };
        }
        const images = await getMediaItemsByCategory(cat.id, locale);
        return { id: cat.id, label: cat.label, images };
      }),
  )).filter((cat): cat is { id: string; label: string; images: ImageWithAlt[] } => cat !== null);

  // Filter out empty categories
  const categoriesWithImages = loadedCategories.filter((cat) => cat.images.length > 0);

  // Second pass: build the "all" entry if requested
  const allEntry = contentCategories.find((cat: { id: string }) => cat.id === 'all');
  const allImages: ImageWithAlt[] = allEntry
    ? categoriesWithImages.flatMap((cat) => cat.images)
    : [];

  // Build final display list in content-defined order
  for (const cat of contentCategories) {
    if (cat.id === 'all') {
      if (allImages.length > 0) {
        displayCategories.push({ id: 'all', label: allEntry!.label, images: allImages });
      }
    } else {
      const loaded = categoriesWithImages.find((c) => c.id === cat.id);
      if (loaded) {
        displayCategories.push({ id: loaded.id, label: loaded.label, images: loaded.images });
      }
    }
  }
}
---

{!visibility.showMediaPage ? (
  <NotFoundPage />
) : (
  <BaseLayout title={pageContent?.data.title ?? "Media"} description={pageContent?.data.seoDescription}>
    <PageHeroImage
      image={heroImage!}
      alt={heroAlt}
      title={pageContent?.data.title ?? "Media"}
      subtitle={pageContent?.data.subtitle ?? ""}
      shownText={pageContent?.data.shownText}
    />
    {visibility.showMediaContent && (
      <div class="container mx-auto px-4 py-6 sm:py-8 lg:py-12 sm:px-8 lg:px-16">
        {/* Media Categories Accordion */}
        <div class="flex flex-col gap-6 sm:gap-20">
          {
            displayCategories.map((category) => (
              <MediaAccordion
                title={category.label}
                images={category.images}
                cols={4}
                gap="md"
                aspectRatio={category.id === 'people' ? 'native-rows' : 'native'}
                locale={locale}
              />
            ))
          }
        </div>

        {/* Empty State */}
        {
          displayCategories.length === 0 && (
            <div class="text-center py-16 sm:py-20">
              <svg
                class="w-16 h-16 mx-auto mb-4 text-bears-text-onDark/30"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                />
              </svg>
              <p class="text-lg text-bears-text-onDark/60">
                {mediaUiStrings[locale]['no-media']}
              </p>
            </div>
          )
        }
      </div>
    )}
  </BaseLayout>
)}
